# =============================================================================
# OCSD Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# LiteLLM Proxy (required)
# ---------------------------------------------------------------------------
# Your LiteLLM proxy endpoint (OpenAI-compatible)
LITELLM_BASE_URL=http://192.168.0.2:4000/v1
LITELLM_API_KEY=sk-your-key-here

# ---------------------------------------------------------------------------
# Model Groups — mapped to LiteLLM router groups
# Only free-tier groups are used. See router config for fallback chains.
# ---------------------------------------------------------------------------
# Vision: element detection, action confirmation, first-pass mapping
# Routes to: Qwen3 VL → Gemini → local
OCSD_VLM_MODEL=vision

# Quick: fast pre-checks, simple classification (future use)
# Routes to: Gemini 3.1 Flash Lite (thinking)
OCSD_QUICK_MODEL=quick

# Planning: complex path strategy, reasoning (future use)
# Routes to: DeepSeek → Cerebras → local
OCSD_PLANNING_MODEL=planning

# Coding: code gen, UI structure analysis (future use)
# Routes to: Qwen3 → Kimi K2 → Gemini → local
OCSD_CODING_MODEL=coding

# ---------------------------------------------------------------------------
# Local services (optional overrides)
# ---------------------------------------------------------------------------
# Tesseract binary path (auto-detected if on PATH)
# TESSERACT_CMD=/usr/bin/tesseract
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# FAISS index path override
# OCSD_FAISS_INDEX=./assets/faiss.index

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Set to 1 to force local-only mode (no API calls, Ollama fallback)
# OCSD_LOCAL_ONLY=0
